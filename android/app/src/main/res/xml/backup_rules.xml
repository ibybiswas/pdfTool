<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
    Disallow backing up of shared preferences, database and device files
    except for the device's unique identifier to avoid conflicts.
    -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
